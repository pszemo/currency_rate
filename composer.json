{
    "name": "hadnet/currency-rate",
    "description": "PrestaShop 9 module - NBP currency rates display",
    "type": "prestashop-module",
    "license": "AFL-3.0",
    "authors": [
        {
            "name": "HADNET",
            "homepage": "https://hadnet.pl"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "symfony/http-client": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "CurrencyRate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CurrencyRate\\Tests\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
